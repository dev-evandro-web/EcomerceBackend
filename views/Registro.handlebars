<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Cadastro - LUZOLO TEC</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:
    linear-gradient(rgba(0,0,0,.7),rgba(0,0,0,.7)),
    url('https://images.unsplash.com/photo-1519389950473-47ba0277781c?q=80&w=1600&auto=format&fit=crop');

    background-size:cover;
    background-position:center;
    padding:20px;
}

.container{
    width:100%;
    max-width:450px;
    background:rgba(15,23,42,.95);
    padding:40px;
    border-radius:25px;
    box-shadow:0 15px 40px rgba(0,0,0,.5);
    color:white;
}

.logo{
    text-align:center;
    font-size:32px;
    font-weight:bold;
    color:#38bdf8;
    margin-bottom:10px;
}

.subtitle{
    text-align:center;
    margin-bottom:35px;
    color:#cbd5e1;
}

.form-group{
    margin-bottom:20px;
}

.form-group label{
    display:block;
    margin-bottom:8px;
}

.form-group input{
    width:100%;
    padding:15px;
    border:none;
    border-radius:14px;
    background:#1e293b;
    color:white;
    outline:none;
}

.form-group input:focus{
    border:2px solid #38bdf8;
}

.register-btn{
    width:100%;
    padding:16px;
    border:none;
    border-radius:14px;
    background:linear-gradient(90deg,#06b6d4,#2563eb);
    color:white;
    font-size:17px;
    font-weight:bold;
    cursor:pointer;
    transition:.3s;
}

.register-btn:hover{
    transform:scale(1.03);
}

.success-message{
    margin-top:20px;
    background:#16a34a;
    padding:15px;
    border-radius:12px;
    text-align:center;
    display:none;
}

/* BOTÃO ACESSAR */

.access-btn{
    margin-top:20px;
    width:100%;
    padding:15px;
    border:none;
    border-radius:14px;
    background:#38bdf8;
    color:white;
    font-size:16px;
    font-weight:bold;
    cursor:pointer;
    display:block;
    transition:.3s;
}

.access-btn:hover{
    background:#0284c7;
    transform:scale(1.03);
}

</style>
</head>

<body>
  

      {{#if sucess_msg}}
<div class="alert alert-success">
    {{sucess_msg}}
</div>
{{/if}}


{{#if error_msg}}
<div class="alert alert-danger">
    {{error_msg}}
</div>
{{/if}}


{{#if erros}}
<div class="erro-lista">

    {{#each erros}}
        <p>{{msg}}</p>
    {{/each}}

</div>
{{/if}}
      


   
 


    </div>

<div class="container">

<div class="logo">
LUZOLO-TEC
</div>

<p class="subtitle">
Crie a sua conta para acessar a plataforma
</p>

<form id="registerForm" action="/registro/novo" method="POST">

<div class="form-group">
    <label>Nome Completo</label>
    <input
        type="text"
        name="nome"
        placeholder="Digite o seu nome"
        required>
</div>

<div class="form-group">
    <label>Email</label>
    <input
        type="email"
        name="email"
        placeholder="Digite o seu email"
        required>
</div>

<div class="form-group">
    <label>Palavra-passe</label>
    <input
        type="password"
        id="password"
        name="senha"
        required>
</div>

<div class="form-group">
    <label>Confirmar Palavra-passe</label>
    <input
        type="password"
        id="confirmPassword"
        name="confirma_senha"
        required>
</div>

<button type="submit" class="register-btn">
Cadastrar Conta
</button>

</form>


<a href="/ler" class="voltar"></a>

<!-- SUCESSO -->


<!-- BOTÃO ACESSAR -->

<button class="access-btn" id="accessBtn">
    Entrar na Página Inicial
</button>

<p style="text-align:center; margin-top:15px;">
    Já tem uma conta?
    <a href="/login">Fazer login</a>
</p>

</div>

<!-- JAVASCRIPT -->
  <script>
const form = document.getElementById("registerForm");

form.addEventListener("submit", function(e) {

    const password = document.getElementById("password").value;
    const confirmPassword = document.getElementById("confirmPassword").value;

    if (password !== confirmPassword) {
        e.preventDefault();
        alert("As palavras-passe não coincidem!");
    }

});
</script>




</body>
</html>
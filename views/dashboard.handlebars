

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:#0f172a;
    display:flex;
    color:white;
}

/* SIDEBAR */

.sidebar{
    width:260px;
    background:#020617;
    height:100vh;
    position:fixed;
    padding:30px 20px;
    border-right:1px solid rgba(255,255,255,.1);
}

.logo{
    font-size:28px;
    font-weight:bold;
    text-align:center;
    color:#38bdf8;
    margin-bottom:40px;
}

.menu{
    list-style:none;
}

.menu li{
    margin:15px 0;
}

.menu a{
    color:white;
    text-decoration:none;
    display:block;
    padding:14px;
    border-radius:14px;
    transition:.3s;
}

.menu a:hover{
    background:#1e293b;
    transform:translateX(5px);
}

/* MAIN */

.main{
    margin-left:260px;
    width:100%;
    padding:35px;
}

/* TOP */

.top-bar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:30px;
    gap:20px;
    flex-wrap:wrap;
}

.top-bar h1{
    font-size:34px;
}

/* SEARCH */

.search-box{
    background:white;
    padding:12px 20px;
    border-radius:14px;
    display:flex;
    align-items:center;
    width:350px;
}

.search-box input{
    border:none;
    outline:none;
    width:100%;
    font-size:15px;
}

/* BUTTON */

.add-btn{
    background:linear-gradient(90deg,#06b6d4,#2563eb);
    border:none;
    padding:14px 24px;
    border-radius:14px;
    color:white;
    cursor:pointer;
    font-weight:600;
    transition:.3s;
}

.add-btn:hover{
    transform:scale(1.05);
}

/* CART */

.cart-box{
    background:#1e293b;
    padding:14px 20px;
    border-radius:14px;
    cursor:pointer;
    display:flex;
    align-items:center;
    gap:10px;
    font-weight:600;
}

#cart-count{
    background:#38bdf8;
    width:25px;
    height:25px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
}

/* SLIDER */

.slider{
    position:relative;
    width:100%;
    height:350px;
    overflow:hidden;
    border-radius:25px;
    margin-bottom:40px;
}

.slides{
    display:flex;
    width:100%;
    height:100%;
    transition:transform 1s ease-in-out;
}

.slide{
    min-width:100%;
    position:relative;
}

.slide img{
    width:100%;
    height:100%;
    object-fit:cover;
}

.slide-text{
    position:absolute;
    bottom:40px;
    left:40px;
    background:rgba(0,0,0,.55);
    padding:25px;
    border-radius:20px;
}

.slide-text h2{
    margin-bottom:10px;
}

/* NAV SLIDER */

.prev,
.next{
    position:absolute;
    top:50%;
    transform:translateY(-50%);
    width:55px;
    height:55px;
    border:none;
    border-radius:50%;
    background:rgba(0,0,0,.5);
    color:white;
    font-size:24px;
    cursor:pointer;
}

.prev{
    left:20px;
}

.next{
    right:20px;
}

/* DOTS */

.dots{
    position:absolute;
    bottom:20px;
    width:100%;
    text-align:center;
}

.dot{
    width:12px;
    height:12px;
    background:white;
    border-radius:50%;
    display:inline-block;
    margin:0 5px;
    opacity:.5;
    cursor:pointer;
}

.dot.active{
    opacity:1;
    background:#38bdf8;
}

/* PRODUCTS */

.products{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:25px;
}

.card{
    background:#1e293b;
    border-radius:22px;
    overflow:hidden;
    transition:.3s;
}

.card:hover{
    transform:translateY(-10px);
}

.card img{
    width:100%;
    height:240px;
    object-fit:cover;
}

.card-content{
    padding:20px;
}

.price{
    color:#38bdf8;
    font-size:24px;
    font-weight:bold;
    margin:15px 0;
}

.stock{
    color:#22c55e;
    margin-bottom:15px;
}

/* FORM */

.form-box{
    margin-top:45px;
    background:#1e293b;
    padding:30px;
    border-radius:25px;
}

.form-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.input-group{
    display:flex;
    flex-direction:column;
}

.input-group label{
    margin-bottom:8px;
}

.input-group input,
.input-group select,
.input-group textarea{
    padding:14px;
    border:none;
    border-radius:14px;
    outline:none;
    background:#334155;
    color:white;
}

textarea{
    height:120px;
}

/* SAVE */

.save-btn{
    margin-top:25px;
    background:linear-gradient(90deg,#06b6d4,#2563eb);
    border:none;
    padding:16px 28px;
    border-radius:14px;
    color:white;
    font-size:16px;
    font-weight:bold;
    cursor:pointer;
}

/* MODAL CARRINHO */

.cart-modal{
    position:fixed;
    top:0;
    right:-100%;
    width:400px;
    height:100vh;
    background:#020617;
    transition:.5s;
    z-index:9999;
}

.cart-modal.active{
    right:0;
}

.cart-content{
    padding:25px;
    height:100%;
    display:flex;
    flex-direction:column;
}

.cart-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
}

.close-cart{
    background:red;
    color:white;
    border:none;
    width:40px;
    height:40px;
    border-radius:50%;
    cursor:pointer;
}

#cart-items{
    flex:1;
    overflow-y:auto;
}

.cart-item{
    background:#1e293b;
    padding:12px;
    border-radius:15px;
    display:flex;
    gap:15px;
    margin-bottom:15px;
}

.cart-item img{
    width:80px;
    height:80px;
    border-radius:12px;
    object-fit:cover;
}

.remove-btn{
    margin-top:10px;
    background:#ef4444;
    color:white;
    border:none;
    padding:8px 12px;
    border-radius:10px;
    cursor:pointer;
}

.checkout-btn{
    width:100%;
    margin-top:15px;
    background:linear-gradient(90deg,#06b6d4,#2563eb);
    border:none;
    padding:15px;
    border-radius:14px;
    color:white;
    font-size:16px;
    font-weight:bold;
    cursor:pointer;
}

/* RESPONSIVO */

@media(max-width:900px){

.sidebar{
    display:none;
}

.main{
    margin-left:0;
}

.cart-modal{
    width:100%;
}

}

</style>




